# NeMo-Ray — environment variable template
# Copy this file to `.env.local` and fill in the values below.
# `.env.local` is gitignored and must never be committed.

# Cesium Ion access token (used by the CesiumJS globe in the browser).
# Create one at https://ion.cesium.com/tokens
# Must be prefixed with NEXT_PUBLIC_ so Next.js exposes it to the client.
NEXT_PUBLIC_CESIUM_ION_TOKEN=
