# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# Required — MapTiler API key for map tiles, terrain DEM, and style.
# Free tier covers development usage. Sign up at https://maptiler.com
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key_here

# Required — Cesium Ion access token (backs the globe surface the OSM twin renders on).
# Free tier: 10 GB/month. Sign up at https://ion.cesium.com → Access Tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# No longer required — the map renders the untextured OSM building twin on the dark
# globe ground, not Google Photorealistic 3D Tiles. Left here only for reference; the
# app no longer reads this key.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
