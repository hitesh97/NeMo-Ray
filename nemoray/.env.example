# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# Agent backend wiring. Leave unset (mock mode) for a UI-only dev loop. To drive
# the real Nemotron resilience agent, set USE_MOCK=false and point API_BASE at the
# agent SSE bridge (agent/nemoray_modelling/server.py, default :8001).
# The /api/agent route then proxies ${API_BASE}/agent, forwarding
# the operator prompt, conversation history and selected mast ids, and streams the
# agent's AgentStreamEvent frames straight back.
#   NEXT_PUBLIC_USE_MOCK=false
#   NEXT_PUBLIC_API_BASE=http://localhost:8001

# Required — MapTiler API key for map tiles, terrain DEM, and style.
# Free tier covers development usage. Sign up at https://maptiler.com
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key_here

# Required — Cesium Ion access token (backs the globe surface the OSM twin renders on).
# Free tier: 10 GB/month. Sign up at https://ion.cesium.com → Access Tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# No longer required — the map renders the untextured OSM building twin on the dark
# globe ground, not Google Photorealistic 3D Tiles. Left here only for reference; the
# app no longer reads this key.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Required for voice features — ElevenLabs API key.
# Used server-side for TTS (text-to-speech) and speech-to-text transcription.
# Sign up at https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs voice ID to use for TTS responses.
# Must be a voice available on your ElevenLabs plan — free tier only allows pre-made voices.
# Leave unset to use Rachel (21m00Tcm4TlvDq8ikWAM), ElevenLabs' free default. Library/cloned
# voices require a paid subscription or you'll get 402 errors from the TTS endpoint.
# ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
