# NeMo-Ray secrets & local config. Copy to `.env` and fill in. NEVER commit `.env`.

# --- cuOpt (mast-placement MILP) -------------------------------------------
# NVIDIA hosted cuOpt key (nvapi-...). Overrides cuopt.api_key in config.yaml.
CUOPT_API_KEY=

# --- Nemotron NIM (local, nvfp4) -------------------------------------------
# NGC key (nvapi-...) used for `docker login nvcr.io` to pull the NIM container.
NGC_API_KEY=
# OpenAI-compatible base URL of the running NIM (host root, NO trailing /v1 —
# the agent posts "/v1/chat/completions" itself). Local NIM default below.
NEMOTRON_BASE_URL=http://localhost:8080
# Model id the server serves (matches --served-model-name in scripts/serve_nemotron.sh;
# see `curl localhost:8080/v1/models`). The stack runs Nemotron-3 Super 120B NVFP4 locally.
NEMOTRON_MODEL=nemotron-3-super
# Reasoning phase for the agent loop: off (recommended) | on. Measured A/B (5 live
# cases): thinking does not change tool selection, costs 2.5-3.5x planner latency per
# step, and only improves the closing summary on long multi-step flows.
NEMOTRON_THINKING=off

# --- Agent <-> twin wiring --------------------------------------------------
# The coverage twin the agent drives over HTTP (src.serve).
TWIN_URL=http://localhost:8000
# Where the agent SSE server listens (the viewer points at this).
AGENT_PORT=8001
